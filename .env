OPENAI_API_KEY=

LLM_MODEL=gpt-4.1-mini
LLM_CONCURRENCY=8
LLM_MAXIMUM_ATTEMPTS=4
LLM_INITIAL_BACKOFF_SECONDS=1.0

EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DEVICE=auto
SPACY_MODEL=en_core_web_sm

MAXIMUM_SEGMENT_TOKENS=500
SEMANTIC_SIMILARITY_THRESHOLD=0.35
MINIMUM_CLUSTER_SIZE=5
CENTROID_SEGMENT_COUNT=3
TOPIC_RANDOM_STATE=42

CLASSIFY_UTTERANCE_WINDOW=10
CLASSIFY_CONFIDENCE_THRESHOLD=0.7

TOPIC_PROMPT_VERSION=topic-label-v1
FINDINGS_PROMPT_VERSION=segment-findings-v1

ALLOWLIST=Aegis Cloud Security,Aegis Identity
ACCOUNT_PATTERNS=(?i)\b(?:account|customer|case)\s*(?:number|no\.?|id)\s*[:#-]?\s*([A-Z0-9-]{4,})\b
